<!DOCTYPE html> <!-- Copyright 2026 © by Sefinek. All Rights Reserved. -->
<html lang="pl">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Mapa węzłów MeshCore Polska</title>

	<!-- Primary meta -->
	<meta name="description" content="Interaktywna mapa węzłów sieci MeshCore w Polsce i na świecie. Klienci, repeatery, serwery pokoju oraz czujniki na żywo.">
	<meta name="keywords" content="meshcore, mapa meshcore, meshcore polska, mesh, lora, węzły meshcore, repeater meshcore">
	<link rel="canonical" href="https://mapa.meshcorepolska.org/">
	<meta name="theme-color" content="#95010b">

	<!-- Open Graph -->
	<meta property="og:type" content="website">
	<meta property="og:site_name" content="Mapa MeshCore Polska">
	<meta property="og:locale" content="pl_PL">
	<meta property="og:title" content="Mapa węzłów MeshCore Polska">
	<meta property="og:description" content="Interaktywna mapa węzłów sieci MeshCore w Polsce i na świecie.">
	<meta property="og:url" content="https://mapa.meshcorepolska.org/">
	<meta property="og:image" content="https://meshcorepolska.org/images/brand/banner-og.jpg">
	<meta property="og:image:width" content="1200">
	<meta property="og:image:height" content="675">
	<meta property="og:image:alt" content="MeshCore Polska: ogólnopolska społeczność sieci mesh">

	<!-- Twitter / X Card -->
	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:title" content="Mapa węzłów MeshCore Polska">
	<meta name="twitter:description" content="Interaktywna mapa węzłów sieci MeshCore w Polsce i na świecie.">
	<meta name="twitter:image" content="https://meshcorepolska.org/images/brand/banner-og.jpg">
	<meta name="twitter:image:alt" content="MeshCore Polska: ogólnopolska społeczność sieci mesh">

	<!-- JavaScript -->
	<script src="https://cdn.sefinek.net/js/progressbar.js" defer></script>

	<!-- Icons & manifest -->
	<link rel="icon" href="https://meshcorepolska.org/favicon.ico" sizes="16x16 32x32 48x48 64x64 128x128 256x256">
	<link rel="icon" href="https://meshcorepolska.org/images/brand/logo-3-192.png" type="image/png" sizes="192x192">
	<link rel="apple-touch-icon" href="https://meshcorepolska.org/images/brand/logo-3-180.png" sizes="180x180">
	<link rel="manifest" href="/manifest.json">

	<!-- Stylesheets -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;1,800&amp;family=IBM+Plex+Mono:wght@400;500;600&amp;display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/vendor/leaflet/leaflet.css">
	<link rel="stylesheet" href="/vendor/markercluster/MarkerCluster.css">
	<link rel="stylesheet" href="/vendor/markercluster/MarkerCluster.Default.css">
	<link rel="stylesheet" href="/css/style.css">
	<link rel="stylesheet" href="/css/legend.css">
	<link rel="stylesheet" href="/css/modal.css">
	<link rel="stylesheet" href="/css/stats.css">
	<link rel="stylesheet" href="/css/toast.css">

	<!-- schema.org -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "WebApplication",
				"name": "Mapa MeshCore Polska",
				"description": "Interaktywna mapa węzłów sieci MeshCore w Polsce i na świecie.",
				"url": "https://mapa.meshcorepolska.org/",
				"applicationCategory": "UtilitiesApplication",
				"isPartOf": { "@type": "Organization", "name": "MeshCore Polska", "url": "https://meshcorepolska.org/" }
			},
			{
				"@type": "WebSite",
				"name": "Mapa MeshCore Polska",
				"url": "https://mapa.meshcorepolska.org/",
				"inLanguage": "pl-PL"
			}
		]
	}
	</script>
</head>
<body>
<main id="map"></main>
<div id="loading-overlay" role="status" aria-live="polite" aria-label="Ładowanie węzłów" hidden>
	<div class="loading-card">
		<div class="spinner"></div>
		<div class="loading-status" id="loading-status"></div>
		<div class="loading-progress"><div class="loading-progress-bar" id="loading-progress-bar"></div></div>
		<div class="loading-meta" id="loading-meta"></div>
		<button type="button" class="loading-cancel-btn" id="loading-cancel-btn">Anuluj</button>
	</div>
</div>

<header class="stats-bar">
	<a class="brand" href="https://meshcorepolska.org/" target="_blank" rel="noopener" title="MeshCore Polska">
		<img src="https://meshcorepolska.org/images/brand/logo-3-80.png" alt="" width="34" height="34">
		<span class="brand-name">MeshCore <strong>Polska</strong></span>
	</a>
	<span class="stats-divider"></span>
	<span id="stats-counts"></span>
	<button type="button" class="region-toggle-btn" id="stats-toggle" title="Nowe węzły i repeatery">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#chart"></use></svg>
	</button>

	<span class="spacer"></span>
	<form class="search-inline" id="search-form">
		<svg class="icon search-icon" aria-hidden="true"><use href="/icons/icons.svg#search"></use></svg>
		<input type="text" class="text-input" id="search-input" placeholder="Szukaj węzłów..." autocomplete="off">
		<button type="button" class="icon-btn" id="filter-toggle" title="Przełącz filtry">
			<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#filter"></use></svg>
			<span class="filter-active-dot" id="filter-active-dot" hidden></span>
		</button>
	</form>

	<span class="spacer"></span>
	<button type="button" class="region-toggle-btn" id="region-toggle" title="Pokaż wszystkie węzły na świecie">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#globe"></use></svg>
		<span id="region-toggle-label">Tylko Polska</span>
	</button>
	<button type="button" class="region-toggle-btn" id="basemap-toggle" title="Przełącz warstwę mapy">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#layers"></use></svg>
		<span id="basemap-toggle-label">Zmień mapę</span>
	</button>
	<a href="https://github.com/meshcore-pl/map" class="github-link" title="Przejdź do repozytorium GitHub" target="_blank" rel="noopener">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#github"></use></svg>
	</a>
</header>

<menu class="filters-menu" id="node-filter" hidden>
	<li class="filters-row">
		<div class="filters-col filters-col-main">
			<div class="node-type-group">
				<label class="checkbox-label"><input type="checkbox" class="node-type-checkbox" value="1" checked> Klienci</label>
				<label class="checkbox-label"><input type="checkbox" class="node-type-checkbox" value="2" checked> Repeatery</label>
				<label class="checkbox-label"><input type="checkbox" class="node-type-checkbox" value="3" checked> Serwery pokoju</label>
				<label class="checkbox-label"><input type="checkbox" class="node-type-checkbox" value="4" checked> Czujniki</label>
			</div>
			<div class="field-group">
				<label for="from-date">Ostatnia aktualizacja</label>
				<input type="date" class="date-input" id="from-date">
			</div>
			<div class="field-group">
				<label for="from-insert-date">Dodano</label>
				<input type="date" class="date-input" id="from-insert-date">
			</div>
			<div class="field-group">
				<label for="clustering-zoom">Poziom powiększenia grupowania</label>
				<input type="range" id="clustering-zoom" min="10" max="17" value="11">
			</div>
		</div>
		<div class="filters-col filters-col-freq field-group" id="freq-filter-group" hidden>
			<span>Częstotliwość</span>
			<div id="freq-filter-list"></div>
		</div>
	</li>
	<li class="filters-actions">
		<button type="button" class="apply-filters-btn" id="apply-filters-btn">Zastosuj filtry</button>
		<button type="button" class="clear-filters-btn" id="clear-filters-btn" hidden>Wyczyść filtry</button>
	</li>
</menu>

<ul class="search-results" id="search-results" hidden></ul>

<ul class="basemap-menu" id="basemap-menu" hidden></ul>

<div class="fab-stack">
	<button type="button" class="fab fab-secondary" id="settings-toggle" title="Ustawienia">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#settings"></use></svg>
	</button>
	<button type="button" class="fab fab-secondary" id="legend-toggle" title="Legenda mapy">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#info"></use></svg>
	</button>
	<a class="fab fab-primary" title="Dodaj węzeł do mapy" target="_blank" rel="noopener" href="https://github.com/meshcore-dev/MeshCore/blob/main/docs/faq.md#512-q-how-do-i-add-a-node-to-the-meshcore-map">
		<svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#plus"></use></svg>
	</a>
</div>

<div class="modal-overlay" id="region-warning-overlay" hidden>
	<div class="settings-panel region-warning-panel" id="region-warning-panel" role="dialog" aria-modal="true" aria-labelledby="region-warning-title">
		<div class="region-warning-header">
			<span class="region-warning-icon"><svg class="icon" aria-hidden="true"><use href="/icons/icons.svg#warning"></use></svg></span>
			<div class="modal-title" id="region-warning-title">Jesteś tego pewny?</div>
		</div>
		<p class="region-warning-text">
			Dane obejmujące cały świat ważą <span id="region-warning-size">nieznany rozmiar</span>, to znacznie więcej niż same węzły z Polski.
			Jeśli posiadasz limitowany pakiet internetu u operatora, pobranie tylu danych może minimalnie go nadgryźć.
			Na starszych urządzeniach mapa może stać się też trochę mniej responsywna.
		</p>
		<div class="region-warning-actions">
			<button type="button" class="region-warning-btn" id="region-warning-cancel">Anuluj</button>
			<button type="button" class="region-warning-btn region-warning-btn-primary" id="region-warning-confirm">Pobierz mimo to</button>
		</div>
	</div>
</div>

<div class="modal-overlay" id="settings-overlay" hidden>
	<div class="settings-panel" id="settings-panel" role="dialog" aria-modal="true" aria-labelledby="settings-title">
		<div class="modal-title" id="settings-title">Ustawienia</div>

		<div class="setting-item">
			<label class="checkbox-label"><input type="checkbox" id="setting-close-filters-on-apply" checked> Zamykaj okno filtrów po zastosowaniu</label>
			<p class="setting-desc">Po kliknięciu „Zastosuj filtry” panel filtrów zamknie się automatycznie zamiast pozostać otwarty.</p>
		</div>

		<div class="modal-title settings-subtitle">Zaawansowane</div>

		<div class="setting-item">
			<label class="checkbox-label"><input type="checkbox" id="setting-show-openfreemap"> Pokaż OpenFreeMap w przełączniku map</label>
			<p class="setting-desc">Jest to darmowa mapa wektorowa oparta na danych OpenStreetMap. W odróżnieniu od pozostałych map (zwykłe obrazki, kafelki) wymaga dociągnięcia dodatkowej biblioteki renderującej w przeglądarce (~1&nbsp;MB), dlatego jest domyślnie wyłączona. Włącz ją tylko, jeśli faktycznie chcesz z niej skorzystać.</p>
		</div>
	</div>
</div>

<div class="modal-overlay" id="stats-overlay" hidden>
	<div class="stats-panel" id="stats-panel" role="dialog" aria-modal="true" aria-labelledby="stats-title">
		<div class="modal-title" id="stats-title">Nowe węzły</div>
		<div class="stats-chips">
			<div class="stats-chip"><span class="stats-chip-label">24h</span><span class="stats-chip-value" id="stats-chip-24h">0</span></div>
			<div class="stats-chip"><span class="stats-chip-label">7d</span><span class="stats-chip-value" id="stats-chip-7d">0</span></div>
			<div class="stats-chip"><span class="stats-chip-label">30d</span><span class="stats-chip-value" id="stats-chip-30d">0</span></div>
		</div>
		<div class="stats-period-group" role="group" aria-label="Zakres czasu">
			<button type="button" class="stats-period-btn active" data-period="24h">24h</button>
			<button type="button" class="stats-period-btn" data-period="7d">7d</button>
			<button type="button" class="stats-period-btn" data-period="30d">30d</button>
		</div>
		<ul class="stats-repeater-list" id="stats-repeater-list"></ul>
	</div>
</div>

<div class="modal-overlay" id="legend-overlay" hidden>
	<div class="settings-panel legend-panel" id="legend-panel" role="dialog" aria-modal="true" aria-labelledby="legend-title">
		<section class="legend-plans" aria-labelledby="legend-plans-title">
			<div class="modal-title" id="legend-plans-title">Co dalej?</div>
			<p>Planowany jest serwis <a href="https://meshcoreprofiles.com" target="_blank" rel="noopener">meshcoreprofiles.com</a>, zintegrowany z mapą węzłów z całego świata.</p>
			<ul>
				<li>Użytkownicy, którzy wprowadzą dane o companionie lub RPT, otrzymają własny profil.</li>
				<li>Wybrane informacje z profili będą widoczne bezpośrednio na mapie, dzięki czemu będzie można łatwo sprawdzić, do kogo należy dany węzeł.</li>
				<li>Właściciele repeaterów będą mogli przesyłać ich zdjęcia, które następnie zostaną publicznie wyświetlone w serwisie.</li>
			</ul>
			<p>Testowa wersja konfiguratora jest obecnie dostępna wyłącznie dla użytkowników serwera <a href="https://meshcorepolska.org/discord" target="_blank" rel="noopener">Discord MeshCore Polska</a> (komenda <code>/konfigurator</code> od <code>Sefi#6347</code>). <a href="https://beta.sefinek.net/meshcore-pl/kontakty/6a43efd454feb8be5679e0a6" target="_blank" rel="noopener">Zobacz przykładowy</a>.</p>
		</section>

		<div class="legend-columns">
			<div class="legend-col">
				<div class="modal-title" id="legend-title">Rodzaj</div>
				<div class="legend-row"><svg class="legend-icon legend-icon-plain" width="20" height="20"><use href="/icons/node-types.svg#client-plain"></use></svg><span>Klient</span></div>
				<div class="legend-row"><svg class="legend-icon legend-icon-plain" width="20" height="20"><use href="/icons/node-types.svg#repeater-plain"></use></svg><span>Repeater</span></div>
				<div class="legend-row"><svg class="legend-icon legend-icon-plain" width="20" height="20"><use href="/icons/node-types.svg#room-server-plain"></use></svg><span>Serwer pokoju</span></div>
				<div class="legend-row"><svg class="legend-icon legend-icon-plain" width="20" height="20"><use href="/icons/node-types.svg#sensor-plain"></use></svg><span>Czujnik</span></div>
			</div>

			<div class="legend-col">
				<div class="modal-title">Mapa</div>
				<div class="legend-row"><svg class="legend-icon update-recent" width="20" height="20"><use href="/icons/node-types.svg#client"></use></svg><span>Zaktualizowano niedawno</span></div>
				<div class="legend-row"><svg class="legend-icon update-stale" width="20" height="20"><use href="/icons/node-types.svg#client"></use></svg><span>Zaktualizowano jakiś czas temu</span></div>
				<div class="legend-row"><svg class="legend-icon update-old" width="20" height="20"><use href="/icons/node-types.svg#client"></use></svg><span>Dawno nieaktualizowany</span></div>
				<div class="legend-row"><svg class="legend-icon update-extinct" width="20" height="20"><use href="/icons/node-types.svg#client"></use></svg><span>Zostanie wkrótce usunięty</span></div>
				<div class="legend-row"><svg class="legend-icon" width="20" height="20"><use href="/icons/node-types.svg#client"></use></svg><span>Dodano ręcznie</span></div>
			</div>
		</div>

		<div class="legend-footer">
			<div class="legend-footer-meta">
				<div>Wersja witryny: v<%= version %></div>
				<div>Aktualizacja danych: <span id="legend-updated-at">-</span></div>
			</div>
			<button type="button" class="btn btn-outline" id="changelog-toggle">Lista zmian</button>
		</div>
	</div>
</div>

<div class="modal-overlay" id="changelog-overlay" hidden>
	<div class="settings-panel" id="changelog-panel" role="dialog" aria-modal="true" aria-label="Lista zmian">
		<ul class="changelog-list" id="changelog-list"></ul>
	</div>
</div>

<div class="toast-container" id="toast-container" aria-live="polite"></div>

<script src="/vendor/leaflet/leaflet.js"></script>
<script src="/vendor/markercluster/leaflet.markercluster.js"></script>
<script src="/js/map.js" type="module"></script>
</body>
</html>
